# Copiá este archivo a `.env` (gitignoreado) y completá la key.
# Vite la lee como import.meta.env.VITE_GOOGLE_MAPS_KEY (ver src/MapGoogle.jsx).
# Sin key, el mapa cae al fallback de MapLibre (sin key, basemap oscuro).
# En el CI la key va como secret de GitHub (VITE_GOOGLE_MAPS_KEY), no en el repo.
VITE_GOOGLE_MAPS_KEY=
